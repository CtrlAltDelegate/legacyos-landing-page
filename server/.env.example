# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/legacyos

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# ─── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=legacyos-documents
AWS_REGION=us-east-1

# ─── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Polygon.io ────────────────────────────────────────────────────────────────
POLYGON_API_KEY=your-polygon-api-key

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_CORE_ANNUAL=price_your-core-annual-price-id
STRIPE_PRICE_CORE_MONTHLY=price_your-core-monthly-price-id
STRIPE_PRICE_PREMIUM_ANNUAL=price_your-premium-annual-price-id
STRIPE_PRICE_PREMIUM_MONTHLY=price_your-premium-monthly-price-id

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173
