# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/legacyos
# Individual vars used as fallback if DATABASE_URL not set
PGHOST=localhost
PGPORT=5432
PGDATABASE=legacyos
PGUSER=postgres
PGPASSWORD=password

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-token-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=legacyos-documents

# ─── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_CORE=price_your-core-price-id
STRIPE_PRICE_PREMIUM=price_your-premium-price-id

# ─── Polygon.io ────────────────────────────────────────────────────────────────
POLYGON_API_KEY=your-polygon-api-key

# ─── Frontend URL (for CORS) ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
